{
  "$defs": {
    "collection": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "description": "Allowed file extensions for primary prompt files.",
          "items": {
            "pattern": "^\\.[a-z0-9]+$",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "id": {
          "description": "Collection identifier unique within the library.",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "path": {
          "description": "Collection path relative to library.prompts_root and ending with a slash.",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.*/).+/$",
          "type": "string"
        },
        "primary_file": {
          "description": "Primary prompt filename within each prompt directory. Defaults to prompt.md.",
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "path",
        "extensions",
        "primary_file"
      ],
      "type": "object"
    }
  },
  "$id": "https://example.com/schemas/prompt-library.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Schema for an Impromptu prompt library definition.",
  "properties": {
    "collections": {
      "description": "Declared prompt collections relative to library.prompts_root.",
      "items": {
        "$ref": "#/$defs/collection"
      },
      "minItems": 1,
      "type": "array"
    },
    "library": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "description": "Stable library identifier.",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "type": "string"
        },
        "mode": {
          "description": "Library mode. repo = repository-backed, local = local machine only.",
          "enum": [
            "repo",
            "local"
          ],
          "type": "string"
        },
        "name": {
          "description": "Human-readable library name.",
          "minLength": 1,
          "type": "string"
        },
        "prompts_root": {
          "description": "Root directory for prompt collections, relative to the library root and ending with a slash.",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.*/).+/$",
          "type": "string"
        },
        "repository": {
          "additionalProperties": false,
          "description": "Source repository metadata. Required when mode is repo.",
          "properties": {
            "name": {
              "description": "Repository name.",
              "minLength": 1,
              "type": "string"
            },
            "owner": {
              "description": "Repository owner or organization.",
              "minLength": 1,
              "type": "string"
            },
            "provider": {
              "description": "Repository provider, such as github.",
              "minLength": 1,
              "type": "string"
            },
            "url": {
              "description": "Optional canonical repository URL.",
              "format": "uri",
              "type": "string"
            }
          },
          "required": [
            "provider",
            "owner",
            "name"
          ],
          "type": "object"
        }
      },
      "required": [
        "id",
        "name",
        "prompts_root"
      ],
      "type": "object"
    }
  },
  "required": [
    "library",
    "collections"
  ],
  "title": "Impromptu Prompt Library",
  "type": "object"
}
